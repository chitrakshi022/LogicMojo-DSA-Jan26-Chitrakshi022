public static int remove_dupli(List<Integer> arr) {
    // Write your code here
        int count = 1, i=0;
        while(i < arr.size()-1)
        {
            if(arr.get(i) == arr.get(i+1))
                i++;
            else
            {
                count++;
                i++;
            }
        }
        return count;

    }
